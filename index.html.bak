<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#070b10">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>Masri Dental Clinic</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <main class="app">
    <header class="top-header" id="topHeader">
      <div class="brand" id="brandArea">
        <div class="clinic-logo" id="clinicLogo">M</div>
        <div class="brand-text">
          <h1 id="clinicTitle">Masri Dental Clinic</h1>
          <span class="status" id="status">
            <span class="status-dot" id="statusDot"></span>
            Loading...
          </span>
        </div>
      </div>
      <div class="header-right">
        <div class="doctor-card">
          <div class="doctor-name" id="doctorName">Doctor</div>
          <div class="doctor-role" id="doctorRole">Loading...</div>
        </div>
        <button id="refreshBtn" class="icon-btn" aria-label="Refresh" title="Refresh">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="23 4 23 10 17 10"></polyline>
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
          </svg>
        </button>
        <button id="menuBtn" class="menu-btn" aria-label="Menu">Menu</button>
      </div>
    </header>

    <nav class="tabs">
      <button class="tab active" data-page="dashboard">Dashboard</button>
      <button class="tab" data-page="patients">Patients</button>
      <button class="tab" data-page="form">Add Patient</button>
      <button class="tab" data-page="scan">Scan QR</button>
    </nav>

    <!-- Dashboard Page -->
    <section id="dashboard" class="page active">
      <div id="dashboardContent">
        <div class="hero-grid">
          <div class="stat-card"><span class="stat-label">Total Patients</span><strong class="stat-value" data-count="0">--</strong></div>
          <div class="stat-card"><span class="stat-label">Today's Appointments</span><strong class="stat-value" data-count="0">--</strong></div>
          <div class="stat-card"><span class="stat-label">Unpaid Balance</span><strong class="stat-value unpaid" data-count="0">--</strong></div>
          <div class="stat-card"><span class="stat-label">Total Visits</span><strong class="stat-value" data-count="0">--</strong></div>
          <div class="stat-card"><span class="stat-label">Total Revenue</span><strong class="stat-value gold" data-count="0">--</strong></div>
          <div class="stat-card"><span class="stat-label">Paid Today</span><strong class="stat-value gold" data-count="0">--</strong></div>
        </div>

        <div class="quick-actions">
          <button class="btn-primary" onclick="fillForm();showPage('form')">+ New Patient</button>
          <button class="btn-secondary" onclick="showPage('scan')">Scan QR</button>
          <button class="btn-secondary" onclick="backupData()">Backup</button>
          <button class="btn-secondary" onclick="restoreBackup()">Restore</button>
        </div>

        <div class="panel">
          <h2>Dashboard</h2>
          <p class="muted">Data will appear once connected to cloud.</p>
        </div>
      </div>
    </section>

    <!-- Patients Page -->
    <section id="patients" class="page">
      <div class="search-wrap">
        <input id="search" placeholder="Search name, phone, ID, diagnosis..." autocomplete="off">
      </div>
      <div id="list"></div>
    </section>

    <!-- Add/Edit Patient Form -->
    <section id="form" class="page">
      <div class="card">
        <h2 id="formTitle">Add Patient</h2>
        <form id="patientForm">
          <input type="hidden" id="rowId">
          <input type="hidden" id="caseId">

          <div class="form-grid">
            <div class="field">
              <label for="name">Name</label>
              <input id="name" required placeholder="Patient full name">
            </div>
            <div class="field">
              <label for="phone">Phone</label>
              <input id="phone" placeholder="Main phone number">
            </div>
            <div class="field">
              <label for="extraPhones">Extra Phones</label>
              <input id="extraPhones" placeholder="Separate numbers with commas">
            </div>
            <div class="field full">
              <label for="websites">Websites / Social Links</label>
              <input id="websites" placeholder="Separate links with commas">
            </div>
            <div class="field">
              <label for="age">Age</label>
              <input id="age" type="number" placeholder="Age">
            </div>
            <div class="field">
              <label for="gender">Gender</label>
              <select id="gender">
                <option value="">Select gender</option>
                <option>Male</option>
                <option>Female</option>
              </select>
            </div>
            <div class="field full">
              <label for="chiefComplaint">Chief Complaint</label>
              <textarea id="chiefComplaint" placeholder="Main complaint"></textarea>
            </div>
            <div class="field full">
              <label for="medicalAlerts">Medical Alerts</label>
              <textarea id="medicalAlerts" placeholder="Medical conditions, drugs, allergies..."></textarea>
            </div>
            <div class="field full">
              <label for="diagnosis">Diagnosis</label>
              <textarea id="diagnosis" placeholder="Diagnosis"></textarea>
            </div>
            <div class="field full">
              <label for="treatmentPlan">Treatment Plan</label>
              <textarea id="treatmentPlan" placeholder="Treatment plan"></textarea>
            </div>
            <div class="field full">
              <label for="progressNotes">Progress / Visit Notes</label>
              <textarea id="progressNotes" placeholder="Write visit note, date will be saved automatically"></textarea>
            </div>
            <div class="field full">
              <div class="photo-upload">
                <h3>Photos / X-rays</h3>
                <input id="photos" type="file" accept="image/*" multiple>
                <p class="muted">Images are compressed and uploaded to cloud.</p>
                <div id="preview" class="photo-grid"></div>
              </div>
            </div>
          </div>

          <div class="actions-bar">
            <button id="saveBtn" class="btn-primary" type="submit">Save Patient</button>
            <button class="btn-secondary" type="button" onclick="fillForm();showPage('patients')">Cancel</button>
          </div>
        </form>
      </div>
    </section>

    <!-- Patient Detail Page -->
    <section id="detail" class="page">
      <button id="backBtn" class="btn-secondary back-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back
      </button>
      <div id="details"></div>
    </section>

    <!-- QR Scan Page -->
    <section id="scan" class="page">
      <div class="card">
        <h2>Scan Patient QR</h2>
        <div class="scan-box">
          <div id="reader">Camera preview will appear here</div>
        </div>
        <div class="actions-bar">
          <button id="startScan" class="btn-primary">Start Scanner</button>
          <button id="stopScan" class="btn-danger hidden">Stop Scanner</button>
        </div>
      </div>
    </section>
  </main>

  <!-- Photo Modal -->
  <div id="photoModal" class="modal hidden">
    <button id="closePhoto" class="modal-close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <img id="bigPhoto" alt="Patient photo">
  </div>

  <!-- QR Modal -->
  <div id="qrModal" class="modal hidden">
    <button id="closeQr" class="modal-close" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <div class="qr-box">
      <h2>Patient QR</h2>
      <div id="qrcode"></div>
      <p class="muted">Scan to open this patient file.</p>
    </div>
  </div>

  <!-- Photo Viewer -->
  <div id="photoViewer" class="photo-viewer hidden">
    <button class="viewer-close" id="closeViewer" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    <img id="viewerImage" alt="Patient photo">
    <div class="viewer-nav">
      <button id="prevPhoto">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Prev
      </button>
      <button id="nextPhoto">
        Next
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>
  </div>

  <!-- Tooth Edit Modal -->
  <div id="toothModal" class="modal hidden">
    <div class="tooth-edit-box">
      <h2 id="toothModalTitle">Tooth</h2>
      <div class="surface-grid">
        <button class="surface-btn" data-s="M">M</button>
        <button class="surface-btn" data-s="D">D</button>
        <button class="surface-btn" data-s="O">O</button>
        <button class="surface-btn" data-s="B">B</button>
        <button class="surface-btn" data-s="L">L</button>
      </div>
      <div class="status-grid">
        <button class="btn-secondary" onclick="setToothStatus('healthy')">Healthy</button>
        <button class="btn-secondary" onclick="setToothStatus('caries')">Caries</button>
        <button class="btn-secondary" onclick="setToothStatus('filling')">Filling</button>
        <button class="btn-secondary" onclick="setToothStatus('rct')">RCT</button>
        <button class="btn-secondary" onclick="setToothStatus('crown')">Crown</button>
        <button class="btn-secondary" onclick="setToothStatus('missing')">Missing</button>
        <button class="btn-secondary" onclick="setToothStatus('extraction')">Extraction</button>
        <button class="btn-secondary" onclick="setToothStatus('implant')">Implant</button>
      </div>
      <button class="btn-danger" style="width:100%;margin-top:16px" onclick="closeToothPopup()">Cancel</button>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
  <script src="https://unpkg.com/html5-qrcode"></script>
  <script src="app.js"></script>
</body>
</html>
